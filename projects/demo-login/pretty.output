Feature: Login System # features/login.feature:1
  Como um usuário do sistema
  Quero fazer login com minhas credenciais
  Para acessar as funcionalidades protegidas
  Background:   # features/login.feature:6

  Scenario: Login bem-sucedido                                       # features/login.feature:9
    Given que estou na página de login                               # steps/login_steps.py:5
    When preencho username "tomsmith" e senha "SuperSecretPassword!" # steps/login_steps.py:10
    Then vejo mensagem de sucesso "You logged into a secure area!"   # steps/login_steps.py:15
    And consigo ver o botão de logout                                # steps/login_steps.py:29

  Scenario: Login com senha incorreta                        # features/login.feature:14
    Given que estou na página de login                       # steps/login_steps.py:5
    When preencho username "tomsmith" e senha "senha_errada" # steps/login_steps.py:10
    Then vejo mensagem de erro "Your password is invalid!"   # steps/login_steps.py:22

  Scenario: Login com usuário inexistente                                 # features/login.feature:18
    Given que estou na página de login                                    # steps/login_steps.py:5
    When preencho username "usuario_inexistente" e senha "qualquer_senha" # steps/login_steps.py:10
    Then vejo mensagem de erro "Your username is invalid!"                # steps/login_steps.py:22

  Scenario Outline: Login com diferentes credenciais -- @1.1         # features/login.feature:28
    Given que estou na página de login                               # steps/login_steps.py:5
    When preencho username "tomsmith" e senha "SuperSecretPassword!" # steps/login_steps.py:10
    Then vejo resultado "success"                                    # steps/login_steps.py:34

  Scenario Outline: Login com diferentes credenciais -- @1.2   # features/login.feature:29
    Given que estou na página de login                         # steps/login_steps.py:5
    When preencho username "tomsmith" e senha "wrong_password" # steps/login_steps.py:10
    Then vejo resultado "error"                                # steps/login_steps.py:34

  Scenario Outline: Login com diferentes credenciais -- @1.3     # features/login.feature:30
    Given que estou na página de login                           # steps/login_steps.py:5
    When preencho username "invalid_user" e senha "any_password" # steps/login_steps.py:10
    Then vejo resultado "error"                                  # steps/login_steps.py:34

